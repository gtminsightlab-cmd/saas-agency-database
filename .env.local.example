# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored so your secrets never get committed.

# Supabase (seven16group project)
NEXT_PUBLIC_SUPABASE_URL=https://sdlsdovuljuymgymarou.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_m3e3yBnBxycaQpt4mAEN8Q_5fkA8P2s

# Server-only (only needed for data-import scripts that bypass RLS)
# Grab this from Supabase dashboard -> Project Settings -> API -> service_role key
# DO NOT prefix with NEXT_PUBLIC_ or it will leak to the browser.
# SUPABASE_SERVICE_ROLE_KEY=

# Seven16 Group Support integration (readiness only — values land when seven16groupsupport.com ships).
# Architecture rule: Agency Signal is support-INTEGRATABLE, not support-DEPENDENT.
# Stage-1 readiness shipped 2026-05-19 (Session C); widget mount + signed-token + event posting deferred.

# Public (browser-safe)
NEXT_PUBLIC_PRODUCT_SLUG=agencysignal
NEXT_PUBLIC_SUPPORT_URL=https://seven16groupsupport.com

# Server-only (leave blank until seven16groupsupport.com ships).
# Do NOT prefix with NEXT_PUBLIC_ or these will leak to the browser.
SUPPORT_PLATFORM_API_URL=https://seven16groupsupport.com/api/v1
SUPPORT_PLATFORM_API_KEY=
SUPPORT_CONTEXT_SIGNING_SECRET=
SUPPORT_WEBHOOK_SECRET=

# ─── Pre-launch security gates (Tier 2c — captcha + rate limit) ──────────────
# Documents env vars provisioned in Vercel production during SESSION_36
# (LAUNCH_CHECKLIST §A2 — 5/9 GREEN row).
# Family doctrine: reference_family_supabase_security_baseline.md (Tier 4 baseline).
# lib/security/rate-limit.ts is wired against these and gracefully no-ops in
# local dev when unset. lib/security/turnstile.ts is intentionally NOT
# scaffolded — Supabase Auth's native CAPTCHA integration covers /sign-up +
# /sign-in + /auth/forgot-password; no anon-INSERT API endpoints in public
# need separate server-side token verification today. Add a server-side
# helper file when the first marketing-side lead-capture endpoint lands.

# Cloudflare Turnstile (free) — Supabase Auth CAPTCHA backend.
# Site key is public-safe; secret is server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis (free tier) — backs lib/security/rate-limit.ts.
# Local dev without these = rate-limit no-ops. Production MUST set them.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cron + Edge Function shared secrets (provisioned SESSION_33/37) ─────────
# CRON_SECRET — Vercel Cron header for /api/cron/* routes (BACKLOG #3 saved-list
# refresh). Generated via browser DevTools console crypto.randomUUID() per
# SESSION_33; rotated via Vercel dashboard if compromised.
CRON_SECRET=

# EDGE_FN_AUTH_SECRET — 64-char hex; validates Authorization header inside the
# recompute-saved-lists Edge Function (verify_jwt:false pattern per family
# memory feedback_edge_function_verify_jwt_vs_sb_secret). Cron route sends
# `Bearer ${EDGE_FN_AUTH_SECRET}` instead of service-role JWT.
EDGE_FN_AUTH_SECRET=

# ─── Sentry (provisioned SESSION_33-34) ──────────────────────────────────────
# Source-map upload during Vercel build. Token is org-scoped; project + org
# slugs are public-safe.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=seven16
SENTRY_PROJECT=agency-signal

# ─── Stripe (production billing) ────────────────────────────────────────────
# Webhook URL has rotated twice (Stripe preserves signing_secret on URL-only
# edit, so STRIPE_WEBHOOK_SECRET stays the same across both rotations):
#   1. directory.seven16group.com → agencysignal.co (SESSION_38 cutover)
#   2. agencysignal.co → agencysignal.io (2026-05-27 cutover)
# Production webhook endpoint is now https://agencysignal.io/api/stripe/webhook
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── Canonical app URL (rotated 2026-05-27 — was agencysignal.co; before
#     that, was directory.seven16group.com) ─────────────────────────────────
NEXT_PUBLIC_APP_URL=https://agencysignal.io
